{
  "extends": ["html-validate:recommended"],
  "rules": {
    "require-sri": "off",
    "no-inline-style": "off",
    "long-title": "off",
    "no-trailing-whitespace": "off",
    "void-style": "off",
    "prefer-native-element": "off",
    "no-implicit-close": "off",
    "no-implicit-button-type": "off",
    "wcag/h30": "off",
    "wcag/h32": "off",
    "wcag/h37": "off",
    "wcag/h67": "off"
  }
}
