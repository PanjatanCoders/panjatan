{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "off",
    "no-console": "off",
    "semi": ["warn", "always"],
    "eqeqeq": ["warn", "always"],
    "no-var": "warn"
  }
}
